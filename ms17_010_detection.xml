<group name="eternalblue,ms17-010,demo_lab,">

  <rule id="100200" level="12">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\(spoolsv|svchost)\.exe$</field>
    <field name="win.eventdata.image"       type="pcre2">(?i)\\(cmd|powershell)\.exe$</field>
    <field name="win.eventdata.logonId"     type="pcre2">(?i)^0x3e7$</field>
    <description>MS17-010 Exploitation: SYSTEM process spawned a command shell</description>
    <mitre><id>T1203</id></mitre>
    <group>stage1_exploitation,</group>
  </rule>

  <rule id="100202" level="13">
    <if_sid>61613</if_sid>
    <field name="win.eventdata.image"          type="pcre2">(?i)cmd\.exe$</field>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)\\Desktop\\.*\.txt$</field>
    <description>Post-Exploitation: File .txt created on Desktop by cmd.exe</description>
    <mitre><id>T1074.001</id></mitre>
    <group>stage2_artifact,</group>
  </rule>

  <rule id="100900" level="15" timeframe="300">
    <if_sid>100202</if_sid>
    <if_matched_sid>100200</if_matched_sid>
    <same_field>win.system.computer</same_field>
    <description>CRITICAL: MS17-010 Attack Chain - Exploit &amp; Artifact detected on $(win.system.computer)</description>
    <mitre><id>T1190</id><id>T1105</id></mitre>
    <group>attack_chain,critical_alert,</group>
  </rule>

</group>