<group name="sysmon,windows,malware,trojan_virlock,high_fidelity,">

  <rule id="100500" level="15">
    <if_sid>61603</if_sid>
    <options>alert_by_email</options>
    <field name="win.eventdata.image" type="pcre2">(?i)AppData[\\/]+(Local(Low)?|Roaming|Local[\\/]Temp)[\\/]+WINDOWS[\\/]+(lsass|csrss|smss|services|winlogon)\.exe$</field>
    <description>VirLock (T1036.005): System process masquerading detected. The process $(win.eventdata.image) executed from a suspicious AppData directory.</description>
    <mitre><id>T1036.005</id></mitre>
    <group>defense_evasion,masquerading,virlock,ioc,iso_27001_A.12.2.1,soc2_CC6.1,</group>
  </rule>

  <rule id="100551" level="15">
    <if_sid>61607</if_sid>
    <options>alert_by_email</options>
    <field name="win.eventdata.image" type="pcre2">(?i)[\\/]+(lsass|csrss|smss|services|winlogon|iexplorer?)\.exe$</field>
    <field name="win.eventdata.imageLoaded" type="pcre2">(?i)[\\/]+msvbvm60\.dll$</field>
    <description>VirLock CRITICAL (T1055): Anomalous behavior - VB6 runtime ($(win.eventdata.imageLoaded)) was loaded by a core system process $(win.eventdata.image).</description>
    <mitre><id>T1055</id><id>T1036.005</id></mitre>
    <group>defense_evasion,process_injection,critical,virlock,ioc,pci_dss_5.3,nist_800-53_SI-3,</group>
  </rule>

  <rule id="100552" level="13">
    <if_sid>61607</if_sid>
    <field name="win.eventdata.signatureStatus" type="pcre2">(?i)^(Not signed|Invalid|false)$</field>
    <field name="win.eventdata.imageLoaded" type="pcre2">(?i)[\\/](lsass|csrss|smss|services|winlogon|explorer)\.exe$</field>
    <description>Process Masquerading (T1036.005): An unsigned or invalid binary is masquerading with a critical Windows system process name.</description>
    <mitre><id>T1036.005</id><id>T1036.001</id></mitre>
    <group>defense_evasion,masquerading,anomaly,virlock,nist_800_53_SI-7,</group>
  </rule>

  <rule id="100553" level="14">
    <if_sid>61607</if_sid>
    <options>alert_by_email</options>
    <field name="win.eventdata.originalFileName" type="pcre2">(?i)^DATA\.exe$</field>
    <field name="win.eventdata.product" type="pcre2">(?i)^xk$</field>
    <description>VirLock IoC Detected (T1027): Binary loaded with known VirLock internal PE metadata (OriginalFileName: DATA.exe, Product: xk).</description>
    <mitre><id>T1027</id><id>T1036</id></mitre>
    <group>defense_evasion,malware_exec,virlock,ioc,pci_dss_5.2,</group>
  </rule>

  <rule id="100502" level="14">
    <if_sid>61613</if_sid>
    <options>alert_by_email</options>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)(^[A-Z]:[\\/]+(Data\s[a-f0-9]{4,16}|xk)\.exe$|StartUp[\\/]+Empty\.pif$|Windows[\\/]+(xk\.exe|.*[\\/]+(iexplorer?\.exe|Mig2?\.scr|shell\.exe))$)</field>
    <description>VirLock File Drop: Malicious payload dropped at $(win.eventdata.targetFilename). Indicates possible self-replication or persistence attempt.</description>
    <mitre><id>T1546.002</id><id>T1547.001</id><id>T1036.005</id></mitre>
    <group>lateral_movement,persistence,ioc,virlock,</group>
  </rule>

  <rule id="100504" level="14">
    <if_sid>61615</if_sid>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)Policies[\\/]+(Microsoft[\\/]+Windows[\\/]+System[\\/]+DisableCMD|System[\\/]+(DisableRegistryTools|DisableTaskMgr))</field>
    <field name="win.eventdata.details" type="pcre2">^[1-9][0-9]*$</field>
    <description>Defense Evasion (T1562.001): System policy $(win.eventdata.targetObject) was set to $(win.eventdata.details). Attempt to block admin tools (CMD/Registry/TaskMgr).</description>
    <mitre><id>T1562.001</id></mitre>
    <group>defense_evasion,virlock,nist_800_53_CM-7,</group>
  </rule>

  <rule id="100506" level="15" frequency="4" timeframe="300" ignore="600">
    <if_matched_group>virlock</if_matched_group>
    <same_field>win.system.computer</same_field>
    <options>alert_by_email</options>
    <description>OUTBREAK ALERT: Multiple VirLock behaviors detected on host $(win.system.computer) within 5 minutes. Action: ISOLATE IMMEDIATELY.</description>
    <mitre><id>T1036.005</id><id>T1547.001</id></mitre>
    <group>correlation,malware,critical,virlock,pci_dss_11.4,</group>
  </rule>

</group>
