<group name="sysmon,windows,malware_detection,qakbot,high_fidelity">

  <rule id="100806" level="0">
    <if_sid>92031</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)explorer\.exe$</field>
    <description>Tuning: Suppress native discovery noise from explorer.exe.</description>
  </rule>

  <rule id="100807" level="0">
    <if_sid>92910</if_sid>
    <field name="win.eventdata.sourceImage" type="pcre2">(?i)(OneDrive|explorer)\.exe$</field>
    <description>Tuning: Suppress OneDrive/Explorer sync noise.</description>
  </rule>

  <rule id="100821" level="0">
    <if_sid>61609</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)OneDrive\.Sync\.Service\.exe$</field>
    <field name="win.eventdata.imageLoaded" type="pcre2">(?i)BitsProxy\.dll$</field>
    <description>Tuning: Suppress benign BITS proxy loading by OneDrive (Prevents FP on T1197).</description>
  </rule>

  <rule id="100817" level="0">
    <if_sid>61605</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)svchost\.exe$</field>
    <field name="win.eventdata.destinationIp">^224\.0\.0\.251$</field>
    <field name="win.eventdata.destinationPort">^5353$</field>
    <description>Tuning: Suppress benign mDNS traffic noise originating from standard Windows svchost.</description>
  </rule>

  <rule id="100822" level="0">
    <if_group>sysmon</if_group>
    <field name="win.system.eventID">^13$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)[\\/]consent\.exe$</field>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)bam\\\\State\\\\UserSettings</field>
    <description>Tuning: Suppress benign Background Activity Moderator (BAM) registry updates by UAC consent.exe.</description>
  </rule>

  <rule id="100205" level="10">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)[\\/](cmd|powershell|wscript|cscript)\.exe$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)[\\/](excel|winword|outlook|explorer)\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\.lnk|\.iso|\.zip|\.vbs</field>
    <description>Phase 0: Suspicious script interpreter spawned by Office/Explorer.</description>
    <mitre><id>T1204</id><id>T1059</id></mitre>
    <group>initial_access,qbot_stage0,qbot_killchain</group>
  </rule>

  <rule id="100210" level="8">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)[\\/](Downloads|Desktop|AppData|Temp)[\\/].+\.(bin|dat|jpg|png|tmp)\.exe$</field>
    <description>Phase 1: Suspicious double-extension executable from user directory.</description>
    <mitre><id>T1036.007</id></mitre>
    <group>qbot_stage1,qbot_killchain</group>
  </rule>

  <rule id="100211" level="12">
    <if_sid>61613</if_sid>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)AppData\\[a-zA-Z0-9]+\\Microsoft\\[a-zA-Z0-9]{6,15}\.exe$</field>
    <field name="win.eventdata.image" negate="yes" type="pcre2">(?i)(msiexec|wuauclt|TiWorker|OneDrive|setup|MicrosoftEdgeUpdate|ClickToRun)\.exe$</field>
    <description>Payload Staging: Randomized executable dropped in AppData/Microsoft.</description>
    <mitre><id>T1036.005</id></mitre>
    <group>malware_drop,qbot_stage1,qbot_killchain</group>
  </rule>

  <rule id="100220" level="13">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)[\\/](AppData|Temp|Downloads)[\\/].*\.exe$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)[\\/](AppData|Temp|Downloads)[\\/].*\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\.exe["']?\s+[\/\-][Cc](\s|$)</field>
    <description>Phase 2: Executable spawned another executable from suspicious directory (/C).</description>
    <group>malware_exec,qbot_stage1,qbot_killchain</group>
  </rule>

  <rule id="100214" level="10">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)[\\/]cmd\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)ping\s.*[\/\-]n\s+\d{1,3}\s+127\.0\.0\.1</field>
    <description>Anti-Sandbox: Malware spawned cmd ping-delay.</description>
    <group>defense_evasion,qbot_killchain</group>
  </rule>

  <rule id="100262" level="12">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)[\\/](System32|SysWOW64)[\\/](WerFault|slui|wermgr)\.exe$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)[\\/](AppData|Temp|Downloads)[\\/]</field>
    <description>Process Hollowing Prep: System process spawned by untrusted payload.</description>
    <group>qbot_stage2,process_injection,qbot_killchain</group>
  </rule>

  <rule id="100510" level="14">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)schtasks\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(?=.*[\/\-]Create)(?=.*[\/\-]RU\s+.*SYSTEM)(?=.*[\/\-]tr\s+)(?=.*[\/\-]I\s+[a-zA-Z0-9]+)</field>
    <description>QakBot Persistence: SYSTEM task created with random flag (/I).</description>
    <group>persistence,qbot_stage3,qbot_killchain,qbot_persistence_trigger</group>
  </rule>

  <rule id="100514" level="15">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)svchost\.exe$</field>
    <field name="win.eventdata.parentCommandLine" type="pcre2">(?i)Schedule</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\s+[\/\-]I\s+[a-zA-Z0-9]{6,15}</field>
    <description>[CRITICAL] Task Scheduler initiated QakBot payload execution.</description>
    <group>persistence,execution,critical,qbot_killchain</group>
  </rule>

  <rule id="100264" level="10">
    <if_sid>92031</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)net1?\s+accounts</field>
    <field name="win.eventdata.integrityLevel">System</field>
    <description>Suspicious Account Policy Discovery (net accounts) executed as SYSTEM.</description>
    <mitre><id>T1087</id></mitre>
    <group>discovery,qbot_stage4,qbot_killchain</group>
  </rule>

  <rule id="100265" level="12" timeframe="60">
    <if_matched_sid>100264</if_matched_sid>
    <same_field>win.system.computer</same_field>
    <description>QakBot Automated Recon: Multiple discovery commands in a short window.</description>
    <group>discovery,qbot_stage4,qbot_killchain,high_fidelity</group>
  </rule>

  <rule id="100270" level="12">
    <if_sid>92201</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)SysWOW64\\WindowsPowerShell</field>
    <field name="win.eventdata.user">NT AUTHORITY\\SYSTEM</field>
    <description>QakBot Stage 4: 32-bit PowerShell Env Check as SYSTEM (Prep for Script).</description>
    <mitre><id>T1059.001</id></mitre>
    <group>execution,qbot_stage4,qbot_killchain</group>
  </rule>

  <rule id="100275" level="15" timeframe="300">
    <if_sid>100270</if_sid>
    <if_matched_sid>100264</if_matched_sid>
    <same_field>win.system.computer</same_field>
    <description>CRITICAL: Discovery followed by PowerShell execution on same host.</description>
    <group>qbot_killchain,critical,incident_response</group>
  </rule>

  <rule id="100506" level="14">
    <if_group>sysmon</if_group>
    <field name="win.system.eventID">^22$</field>
    <list field="win.eventdata.queryName" lookup="match_key">etc/lists/qakbot_c2_domains</list>
    <description>Phase 5 (C2 Beacon): DNS resolution via Threat Intel list.</description>
    <group>c2,network,qbot_killchain</group>
  </rule>

  <rule id="100530" level="16" timeframe="86400" ignore="3600">
    <if_sid>100514</if_sid>
    <if_matched_group>qbot_stage1</if_matched_group>
    <if_matched_group>qbot_persistence_trigger</if_matched_group>
    <same_field>win.system.computer</same_field>
    <description>CONFIRMED COMPROMISE: Full QakBot Kill-Chain detected (Initial -> Persistence -> Exec).</description>
    <group>kill_chain_full,critical,incident_response</group>
  </rule>

</group>