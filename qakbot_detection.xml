    <mitre><id>T1036.007</id></mitre>
    <group>qbot_stage1,malware_staging</group>
  </rule>

  <rule id="100217" level="10">
    <if_sid>61607</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)([\\/](Downloads|Desktop|AppData|Temp)[\\/].+\.(bin|dat|jpg|png|tmp)\.exe$|AppData\\[a-zA-Z0-9]+\\Microsoft\\[a-zA-Z0-9]{6,15}\.exe$)</field>
