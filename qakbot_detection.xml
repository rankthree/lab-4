    <description>Detects QakBot Stage 1: Correlation of double-extension payload execution, evasive module loading, and UAC manipulation.</description>
    <mitre><id>T1036.007</id><id>T1574.002</id><id>T1548.002</id></mitre>
    <group>initial_access,critical,qbot_stage1,qbot_killchain</group>
  </rule>

  <rule id="100262" level="12">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)[\\/](System32|SysWOW64)[\\/](WerFault|slui|wermgr)\.exe$</field>
