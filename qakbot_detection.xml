    <if_sid>61613</if_sid>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)AppData\\[a-zA-Z0-9]+\\Microsoft\\[a-zA-Z0-9]{6,15}\.exe$</field>
    <field name="win.eventdata.image" negate="yes" type="pcre2">(?i)(msiexec|wuauclt|TiWorker|MicrosoftEdgeUpdate|MusUpdateHandlers|OneDrive|Teams|ClickToRun|OfficeClickToRun|setup)\.exe$</field>
    <description>Detects a non-standard process dropping a randomized executable into a hidden AppData/Microsoft directory.</description>
    <mitre><id>T1036.005</id></mitre>
    <group>malware_drop,persistence_drop,qbot_stage1,pci_dss_5.1,qbot_killchain</group>
  </rule>

  <rule id="100803" level="9">
