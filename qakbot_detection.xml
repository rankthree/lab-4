    <mitre><id>T1574.002</id><id>T1562.001</id></mitre>
    <group>qbot_stage1,defense_evasion,qbot_killchain</group>
  </rule>

  <rule id="100216" level="13">
    <if_sid>61609</if_sid>
    <field name="win.eventdata.imageLoaded" type="pcre2">(?i)[\\/](Downloads|Desktop|AppData|Temp)[\\/].+\.(bin|dat|jpg|png|tmp)\.exe$</field>
    <field name="win.eventdata.signed" type="pcre2">^false$</field>
