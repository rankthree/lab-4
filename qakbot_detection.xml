    <field name="win.eventdata.sourceImage" negate="yes" type="pcre2">(?i)(CrowdStrike|CSFalcon|SentinelOne|SentinelAgent|MsMpEng|TaniumClient|CortexXDR|elastic-agent|WazuhSvc)\.exe$</field>
