<group name="sysmon,windows,malware_detection,high_fidelity">

  <rule id="100806" level="0">
    <if_sid>92031</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)explorer\.exe$</field>
    <description>Suppresses expected behavioral noise from native Windows component explorer.exe.</description>
  </rule>

  <rule id="100807" level="0">
    <if_sid>92910</if_sid>
    <field name="win.eventdata.sourceImage" type="pcre2">(?i)(OneDrive|explorer)\.exe$</field>
    <description>Suppresses expected noise generated by OneDrive and Windows Explorer synchronization.</description>
  </rule>

  <rule id="100809" level="0">
    <if_sid>92219</if_sid>
    <match type="pcre2">(?i)SoftwareDistribution</match>
    <description>Suppresses expected network and file activity originating from Windows Update Agents.</description>
  </rule>

  <rule id="100813" level="0">
    <if_sid>60805,60807,60808,60809</if_sid>
    <field name="win.system.providerName" type="pcre2">^ESENT$</field>
    <description>Suppresses standard Extensible Storage Engine (ESENT) database recovery and replay logs.</description>
  </rule>

  <rule id="100814" level="0">
    <if_sid>60798</if_sid>
    <field name="win.system.providerName" type="pcre2">^ESENT$</field>
    <description>Suppresses standard Extensible Storage Engine (ESENT) database attachment events.</description>
  </rule>

  <rule id="100300" level="0">
    <if_sid>60635</if_sid>
    <field name="win.eventdata.data" type="pcre2">(?i)Microsoft Update Health Tools</field>
    <description>Suppresses noise generated by Microsoft Update Health Tools reconfiguration.</description>
  </rule>

  <rule id="100815" level="0">
    <if_sid>61613</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)svchost\.exe$</field>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)System32\\SleepStudy\\[^\\]+\.etl$</field>
    <description>Suppresses legitimate Service Host (svchost) activity related to SleepStudy power telemetry.</description>
  </rule>

  <rule id="100816" level="0">
    <if_sid>61609</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)System32\\smartscreen\.exe$</field>
    <field name="win.eventdata.imageLoaded" type="pcre2">(?i)urlmon\.dll$</field>
    <description>Suppresses legitimate SmartScreen module loading URLMON.dll for reputation checks.</description>
  </rule>

  <rule id="100210" level="8">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)[\\/](Downloads|Desktop|AppData|Temp)[\\/].+\.(bin|dat|jpg|png|tmp)\.exe$</field>
    <description>Detects a suspicious double-extension executable launched from a user directory.</description>
    <mitre><id>T1036.007</id><id>T1204.002</id></mitre>
    <group>malware_exec,initial_access,qbot_stage1,qbot_killchain</group>
  </rule>

  <rule id="100213" level="14">
    <if_sid>100210</if_sid>
    <field name="win.eventdata.integrityLevel" type="pcre2">^(High|System)$</field>
    <description>Detects a double-extension payload executing with High or System integrity.</description>
    <mitre><id>T1036.007</id><id>T1068</id></mitre>
    <group>privilege_escalation,initial_access,critical,qbot_killchain</group>
  </rule>

